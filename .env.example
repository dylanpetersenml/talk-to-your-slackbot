# Optional: comma-separated Slack user IDs allowed to use the bot.
# If unset, all users are allowed.
# ALLOWED_SLACK_USER_IDS=U12345,U67890

# Optional: OpenAI API key for PandasAI reasoner (natural-language analysis of match stats).
# If unset, the reasoner returns a message that LLM is not configured.
# OPENAI_API_KEY=sk-...
