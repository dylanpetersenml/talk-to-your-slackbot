# Required for posting responses to Slack (Bot User OAuth Token from app config).
# SLACK_BOT_TOKEN=xoxb-...

# Optional: comma-separated Slack user IDs allowed to use the bot.
# If unset, all users are allowed.
# ALLOWED_SLACK_USER_IDS=U12345,U67890

# Required for reasoner: OpenAI API key (Custom GPT / Chat Completions).
# OPENAI_API_KEY=sk-...

# Optional: model for reasoner (default: gpt-4o-mini).
# OPENAI_MODEL=gpt-4o-mini

# Optional: paste your Custom GPT instructions here to use as system prompt.
# CUSTOM_GPT_SYSTEM_PROMPT=You are a pickleball coach...

# Optional: when running with a CLI question, set to post the response to this channel.
# SLACK_CHANNEL_ID=C0XXXXXX

# Optional: port for Slack HTTP server (default 5000). Used when running without args.
# PORT=5000

# Slack app setup (so messages "connect"):
# - Slash command: set Request URL to https://YOUR_HOST/slack/command (e.g. use ngrok for local).
# - To use @mentions: enable Event Subscriptions, set Request URL to https://YOUR_HOST/slack/events,
#   subscribe to "app_mention", and add scope app_mentions:read. Then @mention the bot in a channel.
